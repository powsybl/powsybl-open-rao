{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$id": "resource:/schemas/pst-range-action/pst-range-action-v1.0.json",
  "description": "A range action interface specifying an action on a PST",
  "type": "object",
  "properties": {
    "id": {
      "description": "The unique identifier of the remedial action",
      "type": "string"
    },
    "name": {
      "description": "The name of the remedial action",
      "type": [
        "string",
        "null"
      ]
    },
    "operator": {
      "description": "The operator of the remedial action",
      "type": [
        "string",
        "null"
      ]
    },
    "groupId": {
      "description": "The group identifier of the range action. All range actions which share the same group identifier should have the same setpoint.",
      "type": [
        "string",
        "null"
      ]
    },
    "speed": {
      "description": "The time it takes to trigger the remedial action",
      "type": "number"
    },
    "networkElementId": {
      "description": "The identifier of the network element on which the remedial action applies",
      "type": "string"
    },
    "initialTap": {
      "type": "number"
    },
    "tapToAngleConversionMap": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "ranges": {
      "description": "The list of operational ranges delimiting the bounds of the range action, if several are defined the RAO will only consider their intersection",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rangeType": {
            "description": "The type of range",
            "$ref": "../range-type/range-type-v1.0.json"
          },
          "max": {
            "type": "number"
          },
          "min": {
            "type": "number"
          }
        },
        "additionalProperties": false,
        "required": [
          "rangeType"
        ]
      }
    },
    "freeToUseUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../free-to-use-usage-rule/free-to-use-usage-rule-v1.0.json"
      }
    },
    "onStateUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../on-state-usage-rule/on-state-usage-rule-v1.0.json"
      }
    },
    "onFlowConstraintUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../on-flow-constraint-usage-rule/on-flow-constraint-usage-rule-v1.0.json"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "required": [
    "id",
    "networkElementId",
    "ranges"
  ]
}
