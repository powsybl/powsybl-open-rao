{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$id": "resource:/schemas/crac/crac-v2.9.json",
  "description": "Contingency list, Remedial Actions and additional Constraints",
  "title": "CRAC",
  "type": "object",
  "properties": {
    "type": {
      "const": "CRAC"
    },
    "version": {
      "const": "2.9"
    },
    "info": {
      "description": "Information about the CRAC",
      "type": "string"
    },
    "id": {
      "description": "The unique identifier of the CRAC",
      "type": "string"
    },
    "name": {
      "description": "The name of the CRAC",
      "type": "string"
    },
    "timestamp": {
      "description": "The timestamp of the CRAC",
      "type": "string"
    },
    "instants": {
      "description": "The list of instants at which a CNEC can be monitored and a Remedial Action applied",
      "type": "array",
      "items": {
        "$ref": "../instant/instant-v2.0.json"
      }
    },
    "ra-usage-limits-per-instant": {
      "description": "The list of remedial action usage limitations for each instant",
      "type": "array",
      "items": {
        "$ref": "../ra-usage-limits-per-instant/ra-usage-limits-per-instant-v2.1.json"
      }
    },
    "networkElementsNamePerId": {
      "description": "A map of network element names indexed by their identifiers",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "contingencies": {
      "description": "The list of contingencies to be studied",
      "type": "array",
      "items": {
        "$ref": "../contingency/contingency-v1.0.json"
      }
    },
    "flowCnecs": {
      "description": "The list of flow CNECs to be monitored",
      "type": "array",
      "items": {
        "items": {
          "$ref": "../flow-cnec/flow-cnec-v2.8.json"
        }
      }
    },
    "angleCnecs": {
      "description": "The list of angle CNECs to be monitored",
      "type": "array",
      "items": {
        "items": {
          "$ref": "../angle-cnec/angle-cnec-v1.4.json"
        }
      }
    },
    "voltageCnecs": {
      "description": "The list of voltage CNECs to be monitored",
      "type": "array",
      "items": {
        "items": {
          "$ref": "../voltage-cnec/voltage-cnec-v1.5.json"
        }
      }
    },
    "pstRangeActions": {
      "description": "The list of PST range actions",
      "type": "array",
      "items": {
        "$ref": "../pst-range-action/pst-range-action-v2.8.json"
      }
    },
    "hvdcRangeActions": {
      "description": "The list of HVDC range actions",
      "type": "array",
      "items": {
        "$ref": "../hvdc-range-action/hvdc-range-action-v2.8.json"
      }
    },
    "injectionRangeActions": {
      "description": "The list of injection range actions",
      "type": "array",
      "items": {
        "$ref": "../injection-range-action/injection-range-action-v2.8.json"
      }
    },
    "counterTradeRangeActions": {
      "description": "The list of counter-trade range actions",
      "type": "array",
      "items": {
        "$ref": "../counter-trade-range-action/counter-trade-range-action-v2.8.json"
      }
    },
    "networkActions": {
      "description": "The list of network actions",
      "type": "array",
      "items": {
        "$ref": "../network-action/network-action-v2.9.json"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "type",
    "version",
    "id",
    "name"
  ]
}
