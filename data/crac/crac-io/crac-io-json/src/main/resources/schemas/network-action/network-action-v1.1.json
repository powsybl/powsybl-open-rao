{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$id": "resource:/schemas/network-action/network-action-v1.1.json",
  "description": "Remedial action interface specifying a direct action on the network",
  "type": "object",
  "properties": {
    "id": {
      "description": "The unique identifier of the remedial action",
      "type": "string"
    },
    "name": {
      "description": "The name of the remedial action",
      "type": [
        "string",
        "null"
      ]
    },
    "operator": {
      "description": "The operator of the remedial action",
      "type": [
        "string",
        "null"
      ]
    },
    "speed": {
      "description": "The time it takes to trigger the remedial action",
      "type": "number"
    },
    "injectionSetpoints": {
      "type": "array",
      "items": {
        "$ref": "../injection-setpoint/injection-setpoint-v1.0.json"
      }
    },
    "pstSetpoints": {
      "type": "array",
      "items": {
        "$ref": "../pst-setpoint/pst-setpoint-v1.0.json"
      }
    },
    "topologicalActions": {
      "type": "array",
      "items": {
        "$ref": "../topological-action/topological-action-v1.0.json"
      }
    },
    "switchPairs": {
      "description": "The list of pairs of switches to be operated together, in opposite ways",
      "type": "array",
      "items": {
        "$ref": "../switch-pair/switch-pair-v1.1.json"
      }
    },
    "freeToUseUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../free-to-use-usage-rule/free-to-use-usage-rule-v1.0.json"
      }
    },
    "onStateUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../on-state-usage-rule/on-state-usage-rule-v1.0.json"
      }
    },
    "onFlowConstraintUsageRules": {
      "type": "array",
      "items": {
        "$ref": "../on-flow-constraint-usage-rule/on-flow-constraint-usage-rule-v1.0.json"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
